<?xml version="1.0"?>
<robot name="humanoid_robot">

  <!-- Materials for Visualization -->
  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>
  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.75" rpy="0 0 0"/>
      <mass value="15.0"/>
      <inertia ixx="2.11" ixy="0.0" ixz="0.0" iyy="1.85" iyz="0.0" izz="0.36"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.2 0.5 1.2"/> 
      </geometry>
      <origin xyz="0 0 0.75" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.2 0.5 1.2"/> 
      </geometry>
      <origin xyz="0 0 0.75" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- ==================== HEAD ==================== -->
  <joint name="base_head_joint" type="continuous">
    <parent link="base_link"/>
    <child link="head"/>
    <origin xyz="0 0 1.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="head">
    <inertial>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.018" ixy="0.0" ixz="0.0" iyy="0.018" iyz="0.0" izz="0.018"/>
    </inertial>
    <visual>
      <geometry>
        <sphere radius="0.15"/> 
      </geometry>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.15"/> 
      </geometry>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- ==================== RIGHT ARM ==================== -->
  <joint name="base_right_arm_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_arm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_arm">
    <inertial>
      <origin xyz="0.25 0.25 1" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.00039" ixy="0.0" ixz="0.0" iyy="0.062" iyz="0.0" izz="0.062"/>
    </inertial>
    <visual>
      <geometry>
        <box size=".705 0.05 0.025"/> 
      </geometry>
      <origin xyz="0.25 0.25 1" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size=".705 0.05 0.025"/> 
      </geometry>
      <origin xyz="0.25 0.25 1" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- ==================== LEFT ARM ==================== -->
  <joint name="base_left_arm_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_arm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="left_arm">
    <inertial>
      <origin xyz="0.25 -0.25 1" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.00039" ixy="0.0" ixz="0.0" iyy="0.062" iyz="0.0" izz="0.062"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.705 0.05 0.025"/> 
      </geometry>
      <origin xyz="0.25 -0.25 1" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.705 0.05 0.025"/> 
      </geometry>
      <origin xyz="0.25 -0.25 1" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- ==================== FLAT LINK ==================== -->
  <joint name="base_flat_joint" type="continuous">
    <parent link="base_link"/>
    <child link="flat_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="flat_link">
    <inertial>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia ixx="0.086" ixy="0.0" ixz="0.0" iyy="0.216" iyz="0.0" izz="0.296"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.8 0.5 0.1"/> 
      </geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.8 0.5 0.1"/> 
      </geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- ==================== WHEELS ==================== -->
  <!-- FRONT LEFT -->
  <joint name="base_front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.25 0.3 -0.05" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="front_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0014" ixy="0.0" ixz="0.0" iyy="0.0014" iyz="0.0" izz="0.0025"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.07"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.07"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- FRONT RIGHT -->
  <joint name="base_front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.25 -0.3 -0.05" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="front_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0014" ixy="0.0" ixz="0.0" iyy="0.0014" iyz="0.0" izz="0.0025"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.07"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.07"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- REAR LEFT -->
  <joint name="base_rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.25 0.3 -0.05" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rear_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0014" ixy="0.0" ixz="0.0" iyy="0.0014" iyz="0.0" izz="0.0025"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.07"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.07"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- REAR RIGHT -->
  <joint name="base_rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.25 -0.3 -0.05" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rear_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0014" ixy="0.0" ixz="0.0" iyy="0.0014" iyz="0.0" izz="0.0025"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.07"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.07"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

</robot>



